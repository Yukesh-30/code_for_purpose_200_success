# Database Configuration
DATABASE_URL='postgresql://username:password@hostname:port/dbname?sslmode=require'

# JWT Configuration
JWT_SECRET_KEY='your_super_secret_key_here'
# Flask Configuration
FLASK_APP=main.py
FLASK_ENV=development

# Talk-to-Data Flask Intelligence
APP_TIMEZONE='Asia/Calcutta'
MAX_RESULT_ROWS=500
QUERY_TIMEOUT_SECONDS=20
VECTOR_STORE_PATH='./.chroma'
VECTOR_COLLECTION_NAME='financial_semantics'
ENABLE_LLM=false
LLM_PROVIDER='groq'
LLM_BASE_URL='https://api.groq.com/openai/v1'
LLM_API_KEY=''
MIN_ANALYSIS_ROWS=1
MIN_FORECAST_HISTORY_DAYS=7
IDEAL_FORECAST_HISTORY_DAYS=21
MIN_ANOMALY_TRANSACTIONS=10
ANOMALY_CONTAMINATION=0.05
ANOMALY_IQR_MULTIPLIER=2.5
LOW_CONFIDENCE_THRESHOLD=0.65
LOW_BALANCE_THRESHOLD=100000
VENDOR_CONCENTRATION_THRESHOLD=25
CATEGORY_CONCENTRATION_THRESHOLD=30
EXPENSE_APPROVAL_THRESHOLD=10000
RESERVE_DAYS_TARGET=60
